# Guardian 部署环境变量样本
# 复制为 deploy/.env 后修改

# 控制台访问口令（强烈建议改成强密钥）
ACCESS_TOKEN=guardian-demo-2026

# 对外域名；localhost 时 Caddy 自签本地证书供本机验证
GUARDIAN_DOMAIN=localhost

# Postgres
POSTGRES_USER=guardian
POSTGRES_PASSWORD=guardian
POSTGRES_DB=guardian

# 死人开关倒计时（分钟）
TRIAL_MINUTES=5

# 人话兜底（留空则只用静态目录）
ANTHROPIC_API_KEY=
