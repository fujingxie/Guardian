{
    # 全局：admin 关闭，日志走 stdout
    admin off
    auto_https disable_redirects
}

# 单一域名站点；环境变量 GUARDIAN_DOMAIN 控制（默认 localhost：Caddy 会自签本地证书）
http://{$GUARDIAN_DOMAIN} {
    encode zstd gzip

    # API 反代到 backend；WSS 通道也是同一域名，由 backend 升级
    handle /api/* {
        reverse_proxy backend:8080
    }

    # install.sh 脚本反代到 backend
    handle /install.sh {
        reverse_proxy backend:8080
    }

    # 其他请求服务前端静态资源
    handle {
        reverse_proxy web:80
    }
}
